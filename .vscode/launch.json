{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Jest — runner.test.ts",
      "program": "${workspaceFolder}/node_modules/jest/bin/jest.js",
      "args": ["tests/runner.test.ts", "--runInBand"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "runtimeArgs": ["--inspect-brk"],
      "env": { "NODE_ENV": "test" },
      "sourceMaps": true,
      "smartStep": true,
      "skipFiles": ["<node_internals>/", "/node_modules/**"],
      "timeout": 0
    }
  ]
}
